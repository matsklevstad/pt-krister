# Copy this file to .env.local and fill in your values.
# .env.local is gitignored so secrets stay out of version control.

# SimplyReview widget ID (found in your SimplyReview dashboard)
VUE_APP_REVIEW_ID=

# Mailgun credentials (for the contact form)
VUE_APP_MAILGUN_API_KEY=
VUE_APP_MAILGUN_DOMAIN=
